# ============================================================
# Obsidian Team — server environment variables
# Скопируйте этот файл в .env и заполните реальными значениями.
# Реальные секреты НЕ коммитить.
# ============================================================

# --- БД ---
DATABASE_URL=postgresql://obsidian:obsidian@localhost:5432/obsidian_sync_dev

# --- Auth (JWT) ---
# Сгенерировать: openssl rand -base64 64
JWT_SECRET=replace-me-with-strong-random-base64
JWT_REFRESH_SECRET=replace-me-with-different-strong-random-base64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Сервер ---
PORT_WEB=3000
PORT_SOCKET=3001
PUBLIC_URL=http://localhost:3000
STORAGE_PATH=./storage

# --- Регистрация ---
# true — открытая регистрация; false — только по приглашениям (управляется в админке)
OPEN_REGISTRATION=false

# --- SMTP (nodemailer) ---
# В режиме разработки можно оставить пустым — письма пойдут в лог-файл / консоль
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Логи (pino) ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- Bootstrap (первый суперадмин, создаётся через prisma seed) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!Locally

# --- Лимиты (опционально) ---
# Максимальный размер одного файла в байтах. Пусто или 0 — без лимита.
MAX_FILE_SIZE=

# --- Node env ---
NODE_ENV=development
